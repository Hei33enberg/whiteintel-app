{
  "name": "whiteintel-desktop",
  "version": "0.1.6",
  "private": true,
  "description": "WhiteIntel Desktop — private local-RAG companion to whiteintel.dev (Ollama + sqlite-vec, never leaves the machine).",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "node scripts/copy-renderer.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "npm run build && electron .",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.8.9",
    "node-llama-cpp": "^3.4.0",
    "pdf-parse": "^1.1.1",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "typescript": "^5.6.2"
  }
}
