{
  "name": "whiteintel-mobile",
  "version": "0.1.2",
  "private": true,
  "description": "WhiteIntel for Android + iOS — Capacitor 6 native shell over whiteintel.dev. Local-RAG on mobile is roadmapped for v0.2.",
  "scripts": {
    "init:android": "cap add android",
    "init:ios": "cap add ios",
    "sync": "cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "build:android": "cap sync android && cd android && ./gradlew assembleRelease",
    "build:android:debug": "cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.5",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.3",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/network": "^6.0.4",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/assets": "^3.0.5",
    "typescript": "^5.6.2"
  }
}
